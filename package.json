{
  "name": "enpal-track",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @enpal/db generate",
    "db:push": "pnpm --filter @enpal/db push",
    "db:seed": "pnpm --filter @enpal/db seed",
    "db:studio": "pnpm --filter @enpal/db studio"
  },
  "devDependencies": {
    "turbo": "^2.5.5"
  },
  "engines": {
    "node": ">=24"
  }
}